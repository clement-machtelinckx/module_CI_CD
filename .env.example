# Vercel backend production variables to configure in the Vercel dashboard:
# MYSQL_HOST=
# MYSQL_DATABASE=
# MYSQL_USER=
# MYSQL_ROOT_PASSWORD=
# MYSQL_PORT=3306
# ADMIN_PASSWORD_SALT=
# ADMIN_TOKEN_SECRET=
#
# EMAIL_ADMIN and PASSWORD_ADMIN are used by the database initialization
# migrations. Vercel will not create the production admin user by itself.
